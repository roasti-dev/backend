[Unit]
Description=Roasti Backend Service
After=network.target

[Service]
Type=simple
User=roasti
Group=roasti
WorkingDirectory=/var/lib/roasti
ExecStart=/usr/local/bin/roasti
EnvironmentFile=/var/lib/roasti/.env
Restart=always
RestartSec=3
StartLimitIntervalSec=60
StartLimitBurst=5

[Install]
WantedBy=multi-user.target