{
  "permissions": {
    "allow": [
      "Bash(ast-index *)"
    ]
  },
  "enabledPlugins": {
    "ast-index@ast-index-marketplace": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit:*.go|Write:*.go",
        "hooks": [
          {
            "type": "command",
            "command": "gofmt -w \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          }
        ]
      }
    ]
  }
}
